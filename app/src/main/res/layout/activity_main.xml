<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- App icon + name -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:src="@drawable/ic_launcher"
            android:contentDescription="@string/ime_name" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/ime_name"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/ime_version"
            android:textSize="13sp"
            android:textColor="#888"
            android:layout_marginBottom="24dp" />

        <!-- Status indicator -->
        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textSize="14sp"
            android:gravity="center"
            android:background="#EEEEEE"
            android:layout_marginBottom="24dp" />

        <!-- Instruction -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/activity_info"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Step 1: Enable -->
        <Button
            android:id="@+id/button_enable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:onClick="openLanguageSetting"
            android:text="@string/activity_setting_button"
            android:layout_marginBottom="8dp" />

        <!-- Step 2: Select default -->
        <Button
            android:id="@+id/button_select"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:onClick="selectInputMethod"
            android:text="@string/activity_select_button"
            android:layout_marginBottom="24dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="16dp" />

        <!-- Settings -->
        <Button
            android:id="@+id/button_settings"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:onClick="openSettings"
            android:text="@string/action_settings" />

        <!-- Privacy Policy -->
        <Button
            android:id="@+id/button_privacy"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:onClick="showPrivacyPolicy"
            android:text="@string/action_privacy_policy" />

        <!-- About -->
        <Button
            android:id="@+id/button_about"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:onClick="showAboutBox"
            android:text="@string/pref_about" />

    </LinearLayout>
</ScrollView>

